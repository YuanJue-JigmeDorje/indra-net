# macOS
.DS_Store

# 源文本永不入库（受版权保护，不公开）
# Source texts NEVER tracked — copyright protected
source/*/raw/
source/*/collated/
source/*/chapter_md/

# 但保留 source/ 顶层 README 用于说明文件放置规范
!source/README.md
!source/*/README.md

# 临时与缓存
*.tmp
*.bak
*.swp
.cache/
__pycache__/
*.pyc
node_modules/

# 编辑器
.idea/
.vscode/
*.iml

# 构建产物
dist/
build/
.next/

# 环境变量
.env
.env.local

# Dictionary raw files (too large)
resources/dictionaries/raw/
resources/dictionaries/*_headwords.txt
